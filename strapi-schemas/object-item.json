{
  "kind": "collectionType",
  "collectionName": "object_items",
  "info": {
    "singularName": "object-item",
    "pluralName": "object-items",
    "displayName": "Object Item",
    "description": "An icon-driven item for features, services, team cards, etc. Referenced by Object Block."
  },
  "options": {
    "draftAndPublish": true
  },
  "attributes": {
    "name": {
      "type": "string",
      "required": true
    },
    "icon": {
      "type": "media",
      "multiple": false,
      "required": false,
      "allowedTypes": ["images", "files"]
    },
    "title": {
      "type": "string"
    },
    "blurb": {
      "type": "text"
    },
    "backgroundColour": {
      "type": "string"
    },
    "primaryButtonLink": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "api::link.link"
    },
    "secondaryButtonLink": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "api::link.link"
    }
  }
}
