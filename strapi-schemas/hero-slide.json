{
  "kind": "collectionType",
  "collectionName": "hero_slides",
  "info": {
    "singularName": "hero-slide",
    "pluralName": "hero-slides",
    "displayName": "Hero Slide",
    "description": "A single slide within a Hero Header carousel. Supports background image/video, title, subtitle, and two CTA buttons."
  },
  "options": {
    "draftAndPublish": true
  },
  "attributes": {
    "name": {
      "type": "string",
      "required": true
    },
    "title": {
      "type": "string"
    },
    "subtitle": {
      "type": "text"
    },
    "button1Label": {
      "type": "string"
    },
    "button2Label": {
      "type": "string"
    },
    "theme": {
      "type": "enumeration",
      "enum": ["light", "dark"],
      "default": "light"
    },
    "contentAlignment": {
      "type": "enumeration",
      "enum": ["left", "center", "right"],
      "default": "left"
    },
    "bgColour": {
      "type": "string"
    },
    "bgImage": {
      "type": "media",
      "multiple": false,
      "required": false,
      "allowedTypes": ["images"]
    },
    "button1Link": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "api::link.link"
    },
    "button2Link": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "api::link.link"
    },
    "backgroundVideo": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "api::video.video"
    }
  }
}
