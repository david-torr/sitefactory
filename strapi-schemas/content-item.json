{
  "kind": "collectionType",
  "collectionName": "content_items",
  "info": {
    "singularName": "content-item",
    "pluralName": "content-items",
    "displayName": "Content Item",
    "description": "A rich content card with title, blurb, image, video and dual links. Referenced by Content Block."
  },
  "options": {
    "draftAndPublish": true
  },
  "attributes": {
    "name": {
      "type": "string",
      "required": true
    },
    "title": {
      "type": "string"
    },
    "blurb": {
      "type": "text"
    },
    "image": {
      "type": "media",
      "multiple": false,
      "required": false,
      "allowedTypes": ["images"]
    },
    "bgColour": {
      "type": "string"
    },
    "alignment": {
      "type": "enumeration",
      "enum": ["left", "center", "right"],
      "default": "left"
    },
    "themeOverride": {
      "type": "enumeration",
      "enum": ["light", "dark"]
    },
    "primaryLink": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "api::link.link"
    },
    "secondaryLink": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "api::link.link"
    },
    "video": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "api::video.video"
    }
  }
}
