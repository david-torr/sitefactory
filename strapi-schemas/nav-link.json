{
  "kind": "collectionType",
  "collectionName": "nav_links",
  "info": {
    "singularName": "nav-link",
    "pluralName": "nav-links",
    "displayName": "Nav Link",
    "description": "A single navigation item with a label and link. Used directly in Site Nav or as children inside a Nav Group."
  },
  "options": {
    "draftAndPublish": false
  },
  "attributes": {
    "name": {
      "type": "string",
      "required": true
    },
    "label": {
      "type": "string",
      "required": true
    },
    "link": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "api::link.link"
    }
  }
}
