{
  "kind": "collectionType",
  "collectionName": "content_blocks",
  "info": {
    "singularName": "content-block",
    "pluralName": "content-blocks",
    "displayName": "Content Block",
    "description": "Flexible grid/carousel block for rich content items (text, image, video, links)."
  },
  "options": {
    "draftAndPublish": true
  },
  "attributes": {
    "name": {
      "type": "string",
      "required": true
    },
    "title": {
      "type": "string"
    },
    "subtitle": {
      "type": "text"
    },
    "titleAlignment": {
      "type": "enumeration",
      "enum": ["left", "center", "right"],
      "default": "left"
    },
    "backgroundColour": {
      "type": "string"
    },
    "backgroundImage": {
      "type": "media",
      "multiple": false,
      "required": false,
      "allowedTypes": ["images"]
    },
    "theme": {
      "type": "enumeration",
      "enum": ["light", "dark"],
      "default": "light"
    },
    "style": {
      "type": "enumeration",
      "enum": ["card", "list", "carousel", "masonry"],
      "default": "card"
    },
    "columns": {
      "type": "integer",
      "default": 3,
      "min": 1,
      "max": 6
    },
    "layout": {
      "type": "enumeration",
      "enum": ["grid", "alternating", "featured"],
      "default": "grid"
    },
    "carouselInterval": {
      "type": "integer",
      "default": 4000,
      "min": 0
    },
    "link": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "api::link.link"
    },
    "items": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::content-item.content-item"
    }
  }
}
